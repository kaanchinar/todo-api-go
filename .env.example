# =============================================
# Todo App - Environment Configuration
# =============================================
# Copy this file to .env and adjust values:
#   cp .env.example .env

# --- Server ---
PORT=8080

# --- JWT Authentication ---
# IMPORTANT: Change this in production! Use a strong random string.
JWT_SECRET=super-secret-key-change-in-production

# --- PostgreSQL ---
# Format: postgres://USER:PASSWORD@HOST:PORT/DB_NAME?sslmode=disable
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/todoapp?sslmode=disable

# --- Redis ---
REDIS_ADDR=localhost:6379
REDIS_PASS=
